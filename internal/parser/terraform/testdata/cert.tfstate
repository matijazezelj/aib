{
  "version": 4,
  "terraform_version": "1.5.0",
  "serial": 1,
  "lineage": "cert-test",
  "outputs": {},
  "resources": [
    {
      "mode": "managed",
      "type": "tls_self_signed_cert",
      "name": "example",
      "provider": "provider[\"registry.terraform.io/hashicorp/tls\"]",
      "instances": [
        {
          "attributes": {
            "name": "example-cert",
            "not_after": "2025-12-31T23:59:59Z"
          },
          "dependencies": []
        }
      ]
    },
    {
      "mode": "managed",
      "type": "tls_self_signed_cert",
      "name": "no_expiry",
      "provider": "provider[\"registry.terraform.io/hashicorp/tls\"]",
      "instances": [
        {
          "attributes": {
            "name": "no-expiry-cert"
          },
          "dependencies": []
        }
      ]
    },
    {
      "mode": "data",
      "type": "tls_certificate",
      "name": "data_source",
      "provider": "provider[\"registry.terraform.io/hashicorp/tls\"]",
      "instances": [
        {
          "attributes": {
            "name": "data-cert"
          },
          "dependencies": []
        }
      ]
    },
    {
      "mode": "managed",
      "type": "unknown_custom_resource",
      "name": "unmapped",
      "provider": "provider[\"registry.terraform.io/hashicorp/custom\"]",
      "instances": [
        {
          "attributes": {
            "name": "unmapped-resource"
          },
          "dependencies": []
        }
      ]
    },
    {
      "mode": "managed",
      "type": "aws_vpc",
      "name": "vpc_with_labels",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "attributes": {
            "name": "vpc-prod",
            "region": "us-east-1",
            "labels": {"env": "prod", "team": "infra"},
            "vpc_id": "vpc-prod"
          },
          "dependencies": []
        }
      ]
    },
    {
      "mode": "managed",
      "type": "aws_subnet",
      "name": "orphan_subnet",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "attributes": {
            "name": "orphan-subnet",
            "vpc_id": "vpc-nonexistent",
            "network": "projects/missing/global/networks/ghost"
          },
          "dependencies": ["aws_vpc.does_not_exist"]
        }
      ]
    }
  ]
}
